---
import "../styles/global.css";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Digital Income Edit™</title>
  <meta name="description" content="The Digital Income Edit™ — a premium educational library for women building online businesses through AI, Pinterest, digital products, and automation." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    body{margin:0;min-height:100vh;position:relative;font-family:"Inter",sans-serif;text-align:center}
    .bg{position:fixed;inset:0;z-index:-2;background-image:url(/images/library/hero-office-wide-04.jpg);background-size:cover;background-position:center}
    .veil{position:fixed;inset:0;z-index:-1;background:linear-gradient(180deg,rgba(251,248,245,.55) 0%,rgba(251,248,245,.85) 55%,var(--cream) 100%)}
    .inner{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;padding:40px 40px 90px}
    h1{font-family:"Fraunces",serif;font-weight:400;font-size:clamp(38px,6vw,64px);color:var(--choc);margin:0 0 18px;text-shadow:0 2px 30px rgba(251,248,245,.9)}
    p{font-family:"Cormorant Garamond",serif;font-style:italic;font-size:22px;color:var(--choc-soft);max-width:520px;margin:0 0 34px}
    a.btn{display:inline-block;background:var(--pink);color:#fff;padding:16px 34px;border-radius:100px;font-size:13px;font-weight:600;letter-spacing:1.4px;text-transform:uppercase;text-decoration:none;box-shadow:0 10px 26px -10px rgba(214,46,115,.55)}
  </style>
</head>
<body>
  <div class="bg"></div>
  <div class="veil"></div>
  <div class="inner">
    <h1>The Digital Income Edit™</h1>
    <p>Build a business you're obsessed with — online, on your terms.</p>
    <a class="btn" href="/learn">Enter The Library →</a>
  </div>
</body>
</html>
