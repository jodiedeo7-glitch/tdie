---
import "../styles/global.css";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Digital Income Edit™</title>
  <meta name="description" content="The Digital Income Edit™ — a premium educational library for women building online businesses through AI, Pinterest, digital products, and automation." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    body{margin:0;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;background:var(--cream);font-family:"Inter",sans-serif;text-align:center;padding:40px}
    h1{font-family:"Fraunces",serif;font-weight:400;font-size:clamp(38px,6vw,64px);color:var(--choc);margin:0 0 18px}
    p{font-family:"Cormorant Garamond",serif;font-style:italic;font-size:22px;color:var(--taupe-deep);max-width:520px;margin:0 0 34px}
    a.btn{display:inline-block;background:var(--pink);color:#fff;padding:16px 34px;border-radius:100px;font-size:13px;font-weight:600;letter-spacing:1.4px;text-transform:uppercase;text-decoration:none}
  </style>
</head>
<body>
  <h1>The Digital Income Edit™</h1>
  <p>Build a business you're obsessed with — online, on your terms.</p>
  <a class="btn" href="/learn">Enter The Library →</a>
</body>
</html>
