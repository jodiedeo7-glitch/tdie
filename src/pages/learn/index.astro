---
import "../../styles/global.css";

// Every published article gets one line added here.
// (Claude will add this line automatically for future articles.)
const articles = [
  {
    title: "How to Build a Faceless Digital Business",
    slug: "how-to-build-a-faceless-digital-business",
    category: "Business Systems",
    readTime: "20 Min Read",
  },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Library | The Digital Income Edit™</title>
  <meta name="description" content="The complete article library from The Digital Income Edit™." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    body{margin:0;background:var(--cream);font-family:"Inter",sans-serif;color:var(--choc);padding:80px 24px}
    .wrap{max-width:760px;margin:0 auto}
    h1{font-family:"Fraunces",serif;font-weight:300;font-size:clamp(34px,5vw,54px);margin:0 0 50px}
    a.row{display:flex;justify-content:space-between;align-items:baseline;padding:26px 0;border-bottom:1px solid var(--gray);text-decoration:none;color:inherit}
    a.row .t{font-family:"Fraunces",serif;font-size:22px}
    a.row .c{font-size:12px;letter-spacing:1.5px;text-transform:uppercase;color:var(--taupe-deep)}
    a.home{display:inline-block;margin-bottom:40px;font-size:13px;letter-spacing:1px;color:var(--taupe-deep);text-decoration:none}
  </style>
</head>
<body>
  <div class="wrap">
    <a class="home" href="/">← Home</a>
    <h1>The Library</h1>
    {articles.map((a) => (
      <a class="row" href={`/learn/${a.slug}`}>
        <span class="t">{a.title}</span>
        <span class="c">{a.category} · {a.readTime}</span>
      </a>
    ))}
  </div>
</body>
</html>
