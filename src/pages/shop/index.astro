---
import PageLayout from "../../layouts/PageLayout.astro";
---
<PageLayout
  title="Shop"
  description="Digital products, templates, and tools from The Digital Income Edit™."
>
  <div class="page-eyebrow">Shop</div>
  <h1>The Shop</h1>
  <p class="lede">Digital products built to remove your next bottleneck — not add another course to your pile.</p>

  <div style="border-top:1px solid var(--gray);margin-top:40px">
    <a href="/shop/plr-vault" style="display:flex;justify-content:space-between;align-items:baseline;padding:26px 0;border-bottom:1px solid var(--gray);text-decoration:none;color:inherit">
      <span style="font-family:'Fraunces',serif;font-size:22px">The PLR Vault™</span>
      <span style="font-size:12px;letter-spacing:1.5px;text-transform:uppercase;color:var(--taupe-deep)">Digital Products</span>
    </a>
  </div>

  <p style="margin-top:60px"><a href="/learn" style="color:var(--pink);font-weight:500">← Back to The Library</a></p>
</PageLayout>
