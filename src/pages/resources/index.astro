---
import PageLayout from "../../layouts/PageLayout.astro";
---
<PageLayout
  title="Free Resources"
  description="Free guides, checklists, and starter tools from The Digital Income Edit™."
>
  <div class="page-eyebrow">The Library</div>
  <h1>Free Resources</h1>
  <p class="lede">Practical, no-fluff starting points — free, and built to move you one real step forward.</p>

  <div style="border-top:1px solid var(--gray);margin-top:40px">
    <a href="/resources/faceless-income-blueprint" style="display:flex;justify-content:space-between;align-items:baseline;padding:26px 0;border-bottom:1px solid var(--gray);text-decoration:none;color:inherit">
      <span style="font-family:'Fraunces',serif;font-size:22px">The Faceless Income Blueprint™</span>
      <span style="font-size:12px;letter-spacing:1.5px;text-transform:uppercase;color:var(--taupe-deep)">Free Guide</span>
    </a>
  </div>

  <p style="margin-top:60px"><a href="/learn" style="color:var(--pink);font-weight:500">← Back to The Library</a></p>
</PageLayout>
