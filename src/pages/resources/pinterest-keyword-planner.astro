---
import "../../styles/global.css";

const SITE = "https://learn.thedigitalincomeedit.com";
const canonical = `${SITE}/resources/pinterest-keyword-planner`;
const PDF = "/pinterest-keyword-planner.pdf";
const FOUNDATIONS = "https://www.skool.com/thedigitalincomeedit/classroom/ede8aaca?md=63eb80fb5d114f77870c962337a58a1b";
const NEWSLETTER_URL = "https://links.thedigitalincomeedit.com/page2";

const title = "The Pinterest Keyword Planner";
const description = "A free planner that takes you from seed words to a bank of 30–50 verified Pinterest keywords, grouped into the topics that become your boards.";

const NAV = [
  { href: "/learn", label: "Learn" },
  { href: "/shop", label: "Shop" },
  { href: "/resources", label: "Resources" },
  { href: "/membership", label: "Membership" },
];

const DRAWER_LINKS = [
  { href: "/learn", label: "Learn" },
  { href: "/shop", label: "Shop" },
  { href: "/resources", label: "Resources" },
  { href: "/membership", label: "Membership" },
  { href: "/community", label: "Community" },
];

const FOOT_LEARN = [
  { href: "/learn", label: "The Library" },
  { href: "/learn", label: "Pinterest" },
  { href: "/learn", label: "AI" },
  { href: "/learn", label: "Digital Products" },
];

const FOOT_EXPLORE = [
  { href: "/shop", label: "Shop" },
  { href: "/resources", label: "Free Resources" },
  { href: "/membership", label: "Membership" },
  { href: "/about", label: "About" },
];

const FOOT_CONNECT = [
  { href: "/community", label: "Community" },
  { href: "/newsletter", label: "Newsletter" },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="google-site-verification" content="c0MzbaUMBCrxCzIuIJfqoxBus1ConcrweH0DkKajo_Y" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | The Digital Income Edit™</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,300;1,9..144,400;1,9..144,500&family=Inter:wght@300;400;500;600&family=Caveat:wght@500;600&display=swap"
    rel="stylesheet"
  />
</head>
<body class="no-js">
  <style>.no-js .mask{clip-path:none!important}.no-js .reveal{opacity:1;transform:none}</style>

  <nav class="nav">
    <div class="nav-in">
      <a class="logo" href="/">The Digital Income <em>Edit™</em></a>
      <div class="nav-links">
        {NAV.map((n) => <a href={n.href}>{n.label}</a>)}
        <a class="nav-join" href="/membership">Join</a>
      </div>
      <button class="burger" id="burger" aria-label="Menu">☰</button>
    </div>
  </nav>

  <div class="drawer" id="drawer">
    <button class="close" id="close" aria-label="Close">✕</button>
    {DRAWER_LINKS.map((n) => <a href={n.href}>{n.label}</a>)}
  </div>

  <div class="masthead reveal">
    <span class="line"></span>
    <span class="issue">Free Resources &nbsp;·&nbsp; <b>Pinterest</b></span>
    <span class="line r"></span>
  </div>

  <div class="hero">
    <span class="kicker">Free Planner</span>
    <h1>The Pinterest Keyword Planner</h1>
    <p class="sub">Keywords are the load-bearing wall of everything on Pinterest. This is where you build yours.</p>
    <div class="hero-meta">
      <span>6 Pages</span>
      <span class="b"></span>
      <span>Printable PDF</span>
      <span class="b"></span>
      <span>Free</span>
    </div>
  </div>
