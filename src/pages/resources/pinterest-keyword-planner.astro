  <script>
    document.body.classList.remove('no-js');
    var io = new IntersectionObserver(function (es) {
      for (var i = 0; i < es.length; i++) {
        if (es[i].isIntersecting) {
          es[i].target.classList.add('in');
          io.unobserve(es[i].target);
        }
      }
    }, { threshold: 0.01, rootMargin: '0px 0px 10% 0px' });
    var reveals = document.querySelectorAll('.reveal');
    for (var r = 0; r < reveals.length; r++) io.observe(reveals[r]);

    var drawer = document.getElementById('drawer');
    document.getElementById('burger').onclick = function () { drawer.classList.add('open'); };
    document.getElementById('close').onclick = function () { drawer.classList.remove('open'); };
    var dlinks = drawer.querySelectorAll('a');
    for (var d = 0; d < dlinks.length; d++) dlinks[d].onclick = function () { drawer.classList.remove('open'); };
  </script>
