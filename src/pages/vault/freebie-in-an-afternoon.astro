---
import PageLayout from "../../layouts/PageLayout.astro";

const CHECKOUT = "https://links.thedigitalincomeedit.com/shop/68a7c033-a060-4c23-9d8b-de7a367ff33c";
const VIP = "/membership";
const VAULT_UNLOCK = "https://links.thedigitalincomeedit.com/shop"; // TODO: replace with $49 Vault Unlock product link when live
---
<PageLayout
  title="Build Your First Freebie in One Afternoon — The Value Vault"
  description="Build a lead magnet AND the paid upsell behind it in one afternoon — on Beacons, selling on autopilot. Done-for-you freebie ideas, templates, swipe copy, and the AI prompts to build it all. $7."
>
  <!-- HERO -->
  <section class="v-hero">
    <div class="v-hero-copy">
      <div class="v-eyebrow">The Value Vault · Quick Win</div>
      <h1>Build Your First Freebie in One Afternoon</h1>
      <p class="v-sub">And have the paid upsell attached — built, live, and ready to sell tomorrow morning.</p>
      <a class="btn" href={CHECKOUT}>Get the Guide — $7 <span class="a">→</span></a>
      <div class="v-price-note">Instant download · or free inside VIP</div>
    </div>

    <div class="v-hero-art">
      <div class="v-cover-wrap">
        <img class="v-cover" src="/images/library/vault-01-cover.png" alt="Build Your First Freebie in One Afternoon — guide cover" />
        <!-- pop graphics -->
        <div class="v-burst">
          <span class="v-burst-in">$7<small>guide</small></span>
        </div>
        <div class="v-badge">★ New in the Vault</div>
        <span class="spark spark-a">✦</span>
        <span class="spark spark-b">✦</span>
        <span class="spark spark-c">✧</span>
        <span class="spark spark-d">✦</span>
      </div>
    </div>
  </section>

  <!-- BODY -->
  <section class="v-body">
    <p class="v-hook">Every woman starting out has a half-built freebie sitting in a folder, waiting until it's "good enough." Here's the truth nobody sells you: <strong>a freebie with no paid offer behind it is just free work.</strong> You give away the download, you get the email, and then… nothing.</p>

    <p>So this guide builds both — the freebie <em>and</em> the small paid offer that rides right behind it — in one afternoon, on Beacons, where it captures emails and sells on autopilot. Not someday. Today, in one sitting.</p>

    <div class="v-inside">
      <div class="v-inside-mark">Let's see what's inside</div>
      <h3>Everything you get</h3>
      <div class="v-num-row"><span class="v-num">1</span><div><h5>5 done-for-you freebie ideas</h5><p>Each one with its upsell already mapped — pick and go.</p></div></div>
      <div class="v-num-row"><span class="v-num">2</span><div><h5>3 fill-in-the-blank templates</h5><p>Plus the exact Canva AI prompt to build each one fast.</p></div></div>
      <div class="v-num-row"><span class="v-num">3</span><div><h5>The $0 "purchase" Beacons setup</h5><p>The trick that captures emails and delivers automatically.</p></div></div>
      <div class="v-num-row"><span class="v-num">4</span><div><h5>Swipe-and-paste copy</h5><p>Delivery message + upsell copy, ready to drop in.</p></div></div>
      <div class="v-num-row"><span class="v-num">5</span><div><h5>The $5–$9 Upsell Menu</h5><p>So you never stall on what to sell next.</p></div></div>
      <div class="v-num-row"><span class="v-num">6</span><div><h5>Copy-paste AI prompts</h5><p>Under every step — heavy on Canva AI.</p></div></div>
    </div>

    <div class="v-expect">
      <div class="v-expect-mark">What to expect</div>
      <h3 class="v-expect-h">By tomorrow morning, you'll have…</h3>
      <div class="v-expect-grid">
        <div class="v-expect-item"><span class="v-expect-ico">✓</span><p>A live lead magnet capturing emails on autopilot</p></div>
        <div class="v-expect-item"><span class="v-expect-ico">✓</span><p>A $5–$9 paid offer attached, ready to sell</p></div>
        <div class="v-expect-item"><span class="v-expect-ico">✓</span><p>The whole funnel built in a single afternoon</p></div>
      </div>
    </div>

    <div class="v-cta-mid">
      <p>By the end of today: a live lead magnet <em>and</em> a small paid offer, selling while you sleep.</p>
      <a class="btn" href={CHECKOUT}>Get the Guide — $7 <span class="a">→</span></a>
    </div>
  </section>

  <!-- CROSS-SELL -->
  <section class="v-cross">
    <div class="v-cross-mark">Or get everything at once</div>
    <p class="v-cross-lead">This is one guide in The Value Vault. Two ways to skip buying them one at a time:</p>
    <div class="v-cross-grid">
      <div class="v-card">
        <h4>Go VIP</h4>
        <p>Unlocks <em>everything</em> inside The Digital Income Edit™ — every Edit, every training, every resource — plus a brand-new Vault guide every single month, free.</p>
        <div class="v-card-price">$27<span>/month</span></div>
        <a href={VIP}>Explore VIP →</a>
      </div>
      <div class="v-card gold">
        <h4>Unlock the Vault</h4>
        <p>Want the whole Value Vault and every future monthly drop, with no subscription? Unlock it all once, keep it forever.</p>
        <div class="v-card-price">$49<span>one-time</span></div>
        <a href={VAULT_UNLOCK}>Unlock the Vault →</a>
      </div>
    </div>
  </section>

  <p class="v-back"><a href="/learn">← Back to The Library</a></p>

  <style>
    main.page-wrap{max-width:1000px;padding:0 24px 100px}

    /* ---------- HERO ---------- */
    .v-hero{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center;
      background:linear-gradient(150deg,var(--pink) 0%,#B8245F 100%);
      border-radius:26px;padding:56px 56px 60px;margin:40px 0 64px;position:relative;overflow:hidden;
      box-shadow:0 30px 60px -20px rgba(214,46,115,.5)}
    .v-hero::before{content:"";position:absolute;width:340px;height:340px;border-radius:50%;
      background:radial-gradient(circle,rgba(255,255,255,.16),transparent 70%);top:-120px;right:-80px}
    .v-hero-copy{position:relative;z-index:2}
    .v-eyebrow{font-size:12px;letter-spacing:2.6px;text-transform:uppercase;color:var(--rose);margin-bottom:20px;font-weight:600}
    .v-hero-copy h1{font-family:"Fraunces",serif;font-weight:400;color:#fff;
      font-size:clamp(32px,4.2vw,48px);line-height:1.04;letter-spacing:-.5px;margin-bottom:20px}
    .v-sub{font-family:"Cormorant Garamond",serif;font-style:italic;font-size:22px;line-height:1.5;color:#FBE9F1;margin-bottom:32px}
    .v-price-note{margin-top:16px;font-size:13px;letter-spacing:.5px;color:var(--rose)}

    .v-hero-art{position:relative;display:flex;justify-content:center;z-index:2}
    .v-cover-wrap{position:relative;width:78%}
    .v-cover{width:100%;border-radius:12px;display:block;
      box-shadow:0 24px 50px -14px rgba(43,22,27,.6);transform:rotate(-3deg)}

    /* price burst */
    .v-burst{position:absolute;bottom:-26px;right:-26px;width:104px;height:104px;
      background:radial-gradient(circle at 38% 32%,#fff,var(--mauve) 60%,var(--pink) 100%);
      border-radius:50%;display:flex;align-items:center;justify-content:center;
      box-shadow:0 12px 26px -6px rgba(43,22,27,.5);transform:rotate(8deg);
      border:3px solid #fff}
    .v-burst-in{font-family:"Fraunces",serif;font-weight:500;font-size:30px;color:var(--choc);
      line-height:.9;text-align:center;display:flex;flex-direction:column}
    .v-burst-in small{font-family:var(--sans);font-size:9px;letter-spacing:1.5px;
      text-transform:uppercase;color:var(--pink);margin-top:2px;font-weight:700}

    /* badge */
    .v-badge{position:absolute;top:-16px;left:-20px;background:var(--gold);color:var(--choc);
      font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;
      padding:8px 16px;border-radius:100px;box-shadow:0 8px 18px -6px rgba(43,22,27,.5);transform:rotate(-6deg)}

    /* sparkles */
    .spark{position:absolute;color:#fff;opacity:.9;font-size:20px}
    .spark-a{top:8%;left:-4%;font-size:26px;color:var(--rose)}
    .spark-b{top:38%;right:-8%;font-size:18px}
    .spark-c{bottom:6%;left:-6%;font-size:22px;color:var(--gold)}
    .spark-d{top:-6%;right:22%;font-size:14px}

    @media(max-width:760px){.v-hero{grid-template-columns:1fr;padding:40px 30px}
      .v-hero-art{order:-1;margin-bottom:8px}.v-cover-wrap{width:62%}}

    /* ---------- BODY ---------- */
    .v-body{max-width:680px;margin:0 auto}
    .v-hook{font-size:19px;line-height:1.7;margin-bottom:22px}
    .v-body p{font-size:17px;line-height:1.8;margin-bottom:22px}
    .v-inside{background:linear-gradient(160deg,var(--rose),var(--cream));border-radius:18px;padding:34px 38px;margin:36px 0}
    .v-inside h3{font-family:"Fraunces",serif;font-weight:500;font-size:24px;color:var(--pink);margin-bottom:20px}
    .v-inside ul{list-style:none;margin:0;padding:0}
    .v-inside li{position:relative;padding-left:34px;margin-bottom:16px;font-size:16px;line-height:1.55}
    .v-inside li::before{content:"✓";position:absolute;left:0;top:0;width:22px;height:22px;
      background:var(--pink);color:#fff;border-radius:50%;font-size:12px;
      display:flex;align-items:center;justify-content:center;font-weight:700}

    .v-cta-mid{text-align:center;background:var(--choc);border-radius:20px;padding:40px;margin:44px 0}
    .v-cta-mid p{font-family:"Cormorant Garamond",serif;font-style:italic;font-size:23px;line-height:1.5;color:#fff;margin-bottom:26px}

    /* ---------- CROSS-SELL ---------- */
    .v-cross{max-width:820px;margin:56px auto 0;padding:44px;background:linear-gradient(160deg,var(--rose),var(--cream));border-radius:22px}
    .v-cross-mark{font-size:12px;letter-spacing:2.6px;text-transform:uppercase;color:var(--gold-deep);margin-bottom:14px;font-weight:600}
    .v-cross-lead{font-family:"Cormorant Garamond",serif;font-style:italic;font-size:21px;color:var(--choc-soft);margin-bottom:30px}
    .v-cross-grid{display:grid;grid-template-columns:1fr 1fr;gap:22px}
    @media(max-width:640px){.v-cross-grid{grid-template-columns:1fr}}
    .v-card{background:#fff;border-radius:16px;padding:30px;border:1px solid rgba(214,46,115,.14)}
    .v-card.gold{border:2px solid var(--gold)}
    .v-card h4{font-family:"Fraunces",serif;font-weight:500;font-size:22px;color:var(--pink);margin-bottom:12px}
    .v-card.gold h4{color:var(--gold-deep)}
    .v-card p{font-size:15px;line-height:1.65;margin-bottom:18px;color:var(--choc-soft)}
    .v-card-price{font-family:"Fraunces",serif;font-size:34px;color:var(--choc);margin-bottom:18px}
    .v-card-price span{font-size:14px;color:var(--taupe-deep);font-family:var(--sans);margin-left:6px}
    .v-card a{font-size:13px;letter-spacing:1px;text-transform:uppercase;font-weight:600;color:var(--pink);text-decoration:none}
    .v-card.gold a{color:var(--gold-deep)}

    .v-back{text-align:center;margin-top:56px}
    .v-back a{color:var(--pink);font-weight:500}

    /* numbered rows */
    .v-inside-mark{font-size:12px;letter-spacing:2.4px;text-transform:uppercase;color:var(--gold-deep);margin-bottom:8px;font-weight:600}
    .v-num-row{display:flex;gap:18px;align-items:flex-start;margin-bottom:18px}
    .v-num{flex:none;width:38px;height:38px;border-radius:50%;background:var(--pink);color:#fff;
      font-family:"Fraunces",serif;font-size:19px;display:flex;align-items:center;justify-content:center;
      box-shadow:0 6px 14px -4px rgba(214,46,115,.5)}
    .v-num-row h5{font-family:"Inter",sans-serif;font-weight:600;font-size:16px;color:var(--choc);margin:4px 0 4px}
    .v-num-row p{font-size:14.5px;line-height:1.55;color:var(--choc-soft);margin:0}

    /* what to expect strip */
    .v-expect{background:linear-gradient(160deg,#F3E7FB,var(--cream));border-radius:20px;padding:38px 40px;margin:44px 0}
    .v-expect-mark{font-size:12px;letter-spacing:2.4px;text-transform:uppercase;color:var(--gold-deep);margin-bottom:8px;font-weight:600;text-align:center}
    .v-expect-h{font-family:"Fraunces",serif;font-weight:500;font-size:26px;color:var(--pink);margin-bottom:26px;text-align:center}
    .v-expect-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:18px}
    @media(max-width:640px){.v-expect-grid{grid-template-columns:1fr}}
    .v-expect-item{background:#fff;border-radius:14px;padding:22px;text-align:center;border:1px solid rgba(203,183,247,.4)}
    .v-expect-ico{display:inline-flex;width:30px;height:30px;border-radius:50%;background:var(--lav,#CBB7F7);
      color:var(--choc);align-items:center;justify-content:center;font-weight:700;margin-bottom:12px}
    .v-expect-item p{font-size:14px;line-height:1.5;color:var(--choc-soft);margin:0}
  </style>
</PageLayout>
