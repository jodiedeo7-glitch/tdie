---
// ============================================================
// THE DIGITAL INCOME EDIT™ — MASTER ARTICLE LAYOUT
// Every article page wraps its content in this layout.
// To publish a new article: create a new file in
// src/pages/learn/ using this same layout, keep the frontmatter
// fields, and write the article body as the page content.
// Nothing here needs to change per-article.
//
// STRUCTURED DATA
// Article schema emits on every page, generated from props.
//
// ⚠️ datePublished is OPTIONAL here so that pages which don't
// pass it still build. It is omitted from the schema when
// absent rather than emitted empty or faked. This is a
// deliberate, temporary state: Google's Article spec lists
// datePublished as REQUIRED, and pages without it will be
// flagged in Search Console and lose article rich-result
// eligibility. Backfill the twelve dates and pass them here.
// No layout change is needed when you do.
//
// FAQPage schema emits only when the optional `faqs` prop is
// passed. Answers passed to `faqs` MUST match the visible FAQ
// text in the article body verbatim — Google penalises
// structured data that isn't present in the rendered page.
//
// ============================================================
// PER-PILLAR ROUTING — Resource Map v2.0, Part 2
// ============================================================
// The journey block below is NO LONGER HARDCODED. It reads
// `category` and routes to that pillar's row.
//
// THE OMISSION RULE (the reason most rows look empty):
// Resource Map v2.0, Part 4 records that ONE of twelve
// free-resource routes and ONE of twelve paid-resource routes
// exist on the live site. Every other route on the map is
// marked "does not exist."
//
// A slot is populated here ONLY if its destination is a live
// page. Where it is not, the slot is OMITTED ENTIRELY and the
// article renders newsletter + community only. We never ship a
// link to a page that isn't there.
//
// This is why Digital Products has three slots and Mindset has
// none. That asymmetry is the true state of the site, not a
// defect in this file. As each route ships, populate its row
// below — one edit, all articles in that pillar update.
//
// LIVE ROUTES AS OF THIS COMMIT (the only ones used):
//   /resources/faceless-income-blueprint   (Pillar 4; also 9, 10)
//   /shop/plr-vault                        (Pillar 4)
//   /membership                            (Membership CTAs)
//
// AFFILIATE MECHANICS — Standing Rule 18:
// link + rel="sponsored" + disclosure travel as a set or not
// at all. Canva (Pillar 3) is the ONLY affiliate with confirmed
// terms and is the ONLY one that ships as a link — it carries
// all three. Make (Pillars 6, 9) and Beacons (Pillar 7) are
// honest recommendations with no confirmed relationship — they
// ship as UNLINKED TEXT with no sponsored rel and no affiliate
// disclosure, because there is no affiliate relationship to
// disclose. They DO carry a plain "not an affiliate link" note:
// that is not an affiliate mechanic, it is the honesty the
// unlinked recommendation exists for. Rule 18 governs the set
// of three; it does not forbid the note. Do not add hrefs to
// Make or Beacons without a recorded decision.
//
// CATEGORY LABELS — Standing Rule 24: the pillar defines the
// label. Keys below are canon. Two live articles pass non-canon
// props and will fall through to DEFAULT until re-tagged:
//   ai-for-online-business.astro:9      'AI & Automation' → 'AI'
//   business-that-runs-without-you.astro:9
//                        'Automation' → 'Automation & Paid Traffic'
// ============================================================
import "../styles/global.css";

export interface Props {
  title: string;             // SEO title tag
  description: string;       // meta description
  slug: string;              // e.g. "how-to-build-a-faceless-digital-business"
  category: string;          // e.g. "Business Systems" — canon label, drives routing
  issueNumber: string;       // e.g. "017"
  readTime: string;          // e.g. "20 Min Read"
  ogImage?: string;
  datePublished?: string;    // ISO 8601, e.g. "2026-07-16". Omitted from schema if absent.
  dateModified?: string;     // ISO 8601. Defaults to datePublished when that exists.
  faqs?: { question: string; answer: string }[];  // Omit for Article schema only.
}

const {
  title,
  description,
  slug,
  category,
  issueNumber,
  readTime,
  ogImage = "/og/default.jpg",
  datePublished,
  dateModified,
  faqs,
} = Astro.props;

const SITE = "https://learn.thedigitalincomeedit.com";
const canonical = `${SITE}/learn/${slug}`;

// Absolute URL for schema and OG — ogImage may be passed as a relative path.
const ogImageAbsolute = ogImage.startsWith("http") ? ogImage : `${SITE}${ogImage}`;

// Dates are spread in only when present. An absent date emits no key at all —
// never an empty string, never a build-time guess.
const articleDates = {
  ...(datePublished && { datePublished }),
  ...((dateModified ?? datePublished) && { dateModified: dateModified ?? datePublished }),
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "@id": `${canonical}#article`,
  headline: title,
  description: description,
  image: ogImageAbsolute,
  url: canonical,
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
  articleSection: category,
  issueNumber: issueNumber,
  ...articleDates,
  inLanguage: "en",
  isAccessibleForFree: true,
  author: {
    "@type": "Organization",
    "@id": `${SITE}/#organization`,
    name: "The Digital Income Edit™",
    url: SITE,
  },
  publisher: {
    "@type": "Organization",
    "@id": `${SITE}/#organization`,
    name: "The Digital Income Edit™",
    url: SITE,
  },
};

const faqSchema = faqs?.length
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "@id": `${canonical}#faq`,
      mainEntity: faqs.map((f) => ({
        "@type": "Question",
        name: f.question,
        acceptedAnswer: { "@type": "Answer", text: f.answer },
      })),
    }
  : null;

// ============================================================
// THE ROUTING TABLE — Resource Map v2.0, Part 2
// ============================================================
// Shape of a pillar row. Every field is optional. An omitted
// field renders no slot at all.
//
//   free      { label, blurb, href }   — href MUST be live
//   paid      { label, blurb, href }   — href MUST be live
//   affiliate { name, blurb, href? }   — href omitted = unlinked
//   newsletter  string  — pillar's newsletter CTA line
//   community   string  — pillar's community CTA line
//
// Newsletter and community lines are quoted verbatim from the
// Resource Map. They are the only two fields populated for
// every pillar, because they are the only two destinations
// that exist for every pillar.

const PILLARS = {
  // --- 1. AI --------------------------------------------------
  // free:  AI CEO Planner™ excerpt — /resources/ai-ceo-planner — DOES NOT EXIST. Omitted.
  // paid:  AI CEO Planner™ — /shop/ai-ceo-planner — DOES NOT EXIST. Omitted.
  // affiliate: None — no public programs. Empty is a PASS.
  "AI": {
    newsletter:
      "Most women use AI like a vending machine. Once a week I'll show you how to use it like a hire.",
    community:
      "There's a daily prompt waiting inside the community. Free. Copy it, run it, post what you got — that's the whole assignment.",
  },

  // --- 2. Pinterest -------------------------------------------
  // free:  Pinterest Keyword Planner — /resources/pinterest-keyword-planner — DOES NOT EXIST. Omitted.
  // paid:  Pinterest Foundations™ — /shop/pinterest-foundations — DOES NOT EXIST. Omitted.
  // affiliate: None — Pinterest pays nothing; Tailwind isn't taught. Empty is a PASS.
  "Pinterest": {
    newsletter:
      "Pinterest isn't social media. Treating it like Instagram is why yours is flat. Weekly, what it actually is.",
    community:
      "Drop your Pinterest URL. Someone will tell you within a day which of your boards is doing nothing.",
  },

  // --- 3. Content Creation ------------------------------------
  // free:  Canva Crash Course — /resources/canva-crash-course — DOES NOT EXIST. Omitted.
  //        (Cheapest gap on the map — PDF is built, only the page is missing. Action B.5.)
  // paid:  Tommy Kate Edit™ — /shop/tommy-kate-edit — DOES NOT EXIST. Omitted.
  // affiliate: Canva — the ONLY pillar where Canva is correct, and the only
  //            affiliate on the site that ships as a link.
  "Content Creation": {
    affiliate: {
      name: "Canva",
      blurb:
        "The tool actually taught in the Canva Crash Course, and the one every Pin and carousel in this business is built in.",
      href: "https://www.canva.com",
    },
    newsletter:
      "Posting more isn't a content strategy. It's a treadmill with a schedule. Weekly, the difference.",
    community:
      "Post the last thing you made. Not the best thing — the last thing. That's the one worth talking about.",
  },

  // --- 4. Digital Products ------------------------------------
  // The only pillar where free and paid both resolve. Not a coincidence
  // worth relying on — it is the pillar the old hardcoded block happened
  // to match.
  // ⚠️ Blueprint carries two OPEN flags (segmentation across four pillars;
  //    page-4 [INSERT] placeholder). Route is live; flags are not fixed here.
  // ⚠️ Vault slug is defective — canon is /shop/pretty-and-paid-plr-vault/
  //    with a 301 (action B.6, unshipped). We link the LIVE slug, not the
  //    canon one, because the canon one 404s today. Change this line the
  //    day the 301 ships.
  // affiliate: None — the product IS the recommendation. Empty is a PASS.
  "Digital Products": {
    free: {
      label: "Faceless Income Blueprint™",
      blurb:
        "The whole shape of a faceless business, on paper, before you spend a dollar building one.",
      href: "/resources/faceless-income-blueprint",
    },
    paid: {
      label: "Pretty & Paid PLR Vault™",
      blurb:
        "Six rebrandable products and three AI transformation workflows, refreshed monthly. $11/month.",
      href: "/shop/plr-vault",
    },
    newsletter:
      "The first product doesn't have to be good. It has to exist. Weekly, why that isn't permission to be lazy.",
    community:
      "Name your product before you build it. Post the name. If nobody understands what it is from the name, that's the real feedback.",
  },

  // --- 5. Affiliate Marketing ---------------------------------
  // free:  Lead²Engine Faceless Blueprint™ — /resources/lead-2-engine-blueprint — DOES NOT EXIST. Omitted.
  // paid:  Leni Loves Collage Edit™ — /shop/leni-loves-collage-edit — DOES NOT EXIST. Omitted.
  // affiliate: UNDECIDED — requires approval gate (Part 5, item 4).
  //            Amazon Associates is a teaching subject, not a recommendation.
  //            Treat as None and pass. Do not fill without a recorded decision.
  "Affiliate Marketing": {
    newsletter:
      "Recommending things you don't own is the fastest money in this business — and the easiest to do badly. Weekly, how to do it well.",
    community:
      "Post the one tool you'd recommend even if nobody paid you. That's your first affiliate link — the community will tell you why.",
  },

  // --- 6. Automation & Paid Traffic ---------------------------
  // free:  Starter Map — /resources/starter-map — DOES NOT EXIST. Omitted.
  //        ⚠️ It IS live on Beacons and carrying a wrong price (action A.1).
  //           Not linked from here. Off-site, and wrong until A.1 ships.
  // paid:  GAP — no standalone product. Resource Map names Membership VIP
  //        ($27/mo) as the CTA. /membership is LIVE, so this slot ships.
  // affiliate: Make — recommended, UNLINKED. No relationship exists
  //            (Decision 11). Honest, taught in Module 6, not monetized.
  "Automation & Paid Traffic": {
    paid: {
      label: "Membership — VIP",
      blurb:
        "The Ads Edit™ and Module 6 live inside VIP. $27/month, and the only place this is taught end to end.",
      href: "/membership",
    },
    affiliate: {
      name: "Make",
      blurb:
        "The automation tool this business actually runs on, and the one taught in Module 6. No affiliate relationship — just the honest answer.",
    },
    newsletter:
      "Doing it by hand isn't discipline. It's a bottleneck. Weekly: one thing you should stop doing yourself.",
    community:
      "Tell the community the one task you did more than five times this week. That's the one we're automating.",
  },

  // --- 7. Email Marketing -------------------------------------
  // free:  Welcome Email Templates — /resources/welcome-email-templates — DOES NOT EXIST.
  //        ⚠️ Also a TIER CONFLICT — currently Premium bonus content inside
  //           The Email Edit™. Do not gate-swap without a decision. Omitted.
  // paid:  GAP — no standalone product. CTA is Membership Premium ($9/mo).
  //        /membership is LIVE, so this slot ships.
  // affiliate: Beacons — recommended, UNLINKED. Referral terms UNCONFIRMED
  //            (Part 5, item 5). Genuinely relevant — it's the brand's own
  //            link-in-bio layer. Unlinked until terms are confirmed.
  "Email Marketing": {
    paid: {
      label: "Membership — Premium",
      blurb:
        "The Email Edit™ is inside Premium. $9/month for the sequences, not the theory.",
      href: "/membership",
    },
    affiliate: {
      name: "Beacons",
      blurb:
        "The link-in-bio and lead-magnet delivery layer this business runs on. Recommended because it's used, not because it pays.",
    },
    newsletter:
      "Your list doesn't want a newsletter. It wants one thing it can't get anywhere else. Weekly, what that is.",
    community:
      "Post your welcome email's subject line. Just the subject line. That's where it's already going wrong.",
  },

  // --- 8. Branding --------------------------------------------
  // 🔴 PILLAR BLOCKED — BAMI unreleased (Decision 15 / action 15.13).
  // free:  Brand Bible Memory Chain — /resources/brand-bible-memory-chain — DOES NOT EXIST. Omitted.
  // paid:  BLOCKED. Standing Rule 23 — unreleased rows are retained and
  //        NEVER routed to. This row is deliberately empty. Do not fill it
  //        with Membership to satisfy a checklist.
  // affiliate: None — branding is taught, not tooled. Empty is a PASS.
  "Branding": {
    newsletter:
      "A brand isn't a colour palette. Yours is probably three fonts and a feeling. Weekly, what it should be instead.",
    community:
      "Post your brand in one sentence. If it takes two, you don't have one yet — and the community will say so.",
  },

  // --- 9. Business Systems ------------------------------------
  // free:  Inherits the Blueprint via Pillar 4 — a cross-reference, not its
  //        own route. The route IS live, so the slot ships. This is the
  //        fourth pillar the Blueprint is load-bearing for (open item 1,
  //        segmentation OPEN).
  // paid:  Business Architecture Blueprint™ — /shop/business-architecture-blueprint
  //        — DOES NOT EXIST. Omitted.
  // affiliate: Make — recommended, UNLINKED. Identical treatment to Pillar 6.
  "Business Systems": {
    free: {
      label: "Faceless Income Blueprint™",
      blurb:
        "The architecture on one page — what the business is, before what you post.",
      href: "/resources/faceless-income-blueprint",
    },
    affiliate: {
      name: "Make",
      blurb:
        "Where the systems in this article stop being diagrams and start running. Named in Module 6. No affiliate relationship.",
    },
    newsletter:
      "Most people don't have a business. They have a job they gave themselves. Weekly, the difference — and how to cross it.",
    community:
      "Post the one thing your business can't do without you. That's not a task. That's the architecture problem.",
  },

  // --- 10. Passive Income -------------------------------------
  // free:  Blueprint, shared. Route is live, so the slot ships.
  //        ⚠️ Load-bearing centre of open item 1. Segmentation OPEN.
  // paid:  ⚠️ GAP + LADDER MISMATCH, severity increased. VIP is confirmed
  //        live at $27/mo and there is NO entry rung beneath it in this
  //        pillar. /membership resolves — but routing the most beginner-coded
  //        category on the site at a $27 flagship tier is precisely open
  //        item 2, and Part 5 item 7 holds it at the gate.
  //        SUPPRESSED PENDING GATE. A live link is not the same as a correct
  //        one. This is the one place this file declines a working route.
  // affiliate: None — passive income is an outcome, not a toolset. PASS.
  "Passive Income": {
    free: {
      label: "Faceless Income Blueprint™",
      blurb:
        "What you front-load, and in what order. The unglamorous half nobody screenshots.",
      href: "/resources/faceless-income-blueprint",
    },
    newsletter:
      "Passive income isn't passive. It's front-loaded. Weekly, what you front-load and in what order.",
    community:
      "Post the last thing you built that earned money while you weren't looking at it. If the answer is nothing, post that.",
  },

  // --- 11. Mindset --------------------------------------------
  // free:  Creator → CEO diagnostic — GAP, needs creation. Nothing exists. Omitted.
  //        (Highest-value gap on the map — the only magnet that routes into
  //         every pillar rather than one.)
  // paid:  GAP BY DESIGN — DO NOT FILL. Mindset is taught inside every module
  //        and is not sold standalone (MOM v3.0, Part 6). This is a deliberate
  //        empty, not a hole. Do not route this pillar at a product to satisfy
  //        the close-out checklist.
  // affiliate: None. Empty is a PASS.
  "Mindset": {
    newsletter:
      "You don't have a discipline problem. You have an identity problem wearing a discipline costume. Weekly, the difference.",
    community:
      "Post the thing you've been 'about to start' for three months. Naming it in public is the whole intervention.",
  },

  // --- 12. Blogging -------------------------------------------
  // free:  Evergreen article checklist — GAP, needs creation. Omitted.
  //        (Fastest gap to build — it's a byproduct of SOP 1 and SOP 2.)
  // paid:  GAP — no curriculum, no product. The CTA is a related pillar's
  //        product, chosen by article topic. That is an editorial decision
  //        per article, not a template default — so nothing ships here.
  // affiliate: None — the obvious pick is WordPress hosting, and this site
  //            runs on Astro/Vercel/GitHub. Recommending a stack you don't
  //            use, for commission, is the forced fit. PASS.
  "Blogging": {
    newsletter:
      "Everyone says blogging is dead. My oldest post is still bringing in leads it wrote three years ago. Weekly, why.",
    community:
      "Post the URL of the one article you're proudest of. The community will find the three links you forgot to add.",
  },
} as const;

// Fallback for an unrecognised category — e.g. the two articles still
// carrying non-canon labels. Newsletter + community only. Never guesses.
const DEFAULT_PILLAR = {
  newsletter:
    "One useful email a week. Tutorials, AI workflows, Pinterest strategy, product ideas.",
  community:
    "The room where women one step ahead answer the question you're about to Google.",
};

const pillar = PILLARS[category as keyof typeof PILLARS] ?? DEFAULT_PILLAR;

const free = "free" in pillar ? pillar.free : null;
const paid = "paid" in pillar ? pillar.paid : null;
const affiliate = "affiliate" in pillar ? pillar.affiliate : null;

// Narrowed once here rather than inline, so the template branches on a
// boolean instead of an `in` check inside JSX.
const affiliateHref =
  affiliate && "href" in affiliate ? affiliate.href : null;

const NEWSLETTER_URL = "https://links.thedigitalincomeedit.com/page2";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="google-site-verification" content="c0MzbaUMBCrxCzIuIJfqoxBus1ConcrweH0DkKajo_Y" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | The Digital Income Edit™</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="article" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageAbsolute} />
  <meta property="og:url" content={canonical} />

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,300;1,9..144,400;1,9..144,500&family=Inter:wght@300;400;500;600&family=Caveat:wght@500;600&display=swap"
    rel="stylesheet"
  />
</head>
<body class="no-js">
  <style>.no-js .mask{clip-path:none!important}.no-js .reveal{opacity:1;transform:none}</style>

  <div class="progress" id="progress"></div>

  <nav class="nav">
    <div class="nav-in">
      <a class="logo" href="/">The Digital Income <em>Edit™</em></a>
      <div class="nav-links">
        <a href="/learn">Learn</a><a href="/shop">Shop</a><a href="/resources">Resources</a><a href="/membership">Membership</a>
        <a class="nav-join" href="/membership">Join</a>
      </div>
      <button class="burger" id="burger" aria-label="Menu">☰</button>
    </div>
  </nav>

  <div class="drawer" id="drawer">
    <button class="close" id="close" aria-label="Close">✕</button>
    <a href="/learn">Learn</a><a href="/shop">Shop</a><a href="/resources">Resources</a><a href="/membership">Membership</a><a href="/community">Community</a>
  </div>

  <div class="masthead reveal">
    <span class="line"></span>
    <span class="issue">The Library &nbsp;·&nbsp; Issue No. <b>{issueNumber}</b> &nbsp;·&nbsp; {category}</span>
    <span class="line r"></span>
  </div>

  <slot name="hero" />

  <div class="shell">
    <aside class="rail-left">
      <slot name="toc" />
    </aside>

    <article class="article">
      <slot />
    </article>

    <aside class="rail-right">
      <div class="rail-card">
        <div class="eye">The Membership</div>
        <h5>Build it with women one step ahead</h5>
        <p>Daily prompts, start-here trainings, and the room that turns reading into building.</p>
        <a class="btn" href="/membership" style="padding:13px 22px;font-size:11px">Explore <span class="a">→</span></a>
      </div>
    </aside>
  </div>

  {/*
    THE JOURNEY BLOCK — routed by category, per Resource Map v2.0.
    Each slot renders only when its pillar row populates it AND its
    destination is live. Pillars with no live routes render nothing here;
    their next step is the newsletter and community sections below, which
    carry that pillar's own copy.
  */}
  {(free || paid || affiliate) && (
    <section class="journey">
      <div class="journey-in reveal">
        <div class="eye">Your next step</div>
        <div class="journey-grid">
          {free && (
            <div class="journey-card">
              <div class="journey-kind">Free resource</div>
              <h4>{free.label}</h4>
              <p>{free.blurb}</p>
              <a class="btn" href={free.href}>Get it free <span class="a">→</span></a>
            </div>
          )}
          {paid && (
            <div class="journey-card">
              <div class="journey-kind">Go deeper</div>
              <h4>{paid.label}</h4>
              <p>{paid.blurb}</p>
              <a class="btn" href={paid.href}>See what's inside <span class="a">→</span></a>
            </div>
          )}
          {affiliate && (
            <div class="journey-card journey-card--tool">
              <div class="journey-kind">The tool I'd use</div>
              <h4>{affiliate.name}</h4>
              <p>{affiliate.blurb}</p>
              {affiliateHref ? (
                <Fragment>
                  
                    class="btn"
                    href={affiliateHref}
                    rel="sponsored nofollow noopener"
                    target="_blank"
                  >Take a look <span class="a">→</span></a>
                  <div class="fine">
                    This is an affiliate link. If you sign up through it, I may earn a
                    commission at no cost to you. I recommend it because I use it.
                  </div>
                </Fragment>
              ) : (
                <div class="fine">Not an affiliate link — just what I use.</div>
              )}
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <slot name="journey" />

  <section class="news">
    <div class="news-in reveal">
      <div class="k">The Weekly Edit</div>
      <h3>Continue learning every week</h3>
      <p>{pillar.newsletter}</p>
      {/*
        The dead form is gone. It was onsubmit="return false" on all twelve
        pages — it collected nothing, ever. Replaced with a link to the live
        signup page rather than a form that pretends to work.
      */}
      <a class="btn" href={NEWSLETTER_URL} rel="noopener">Subscribe <span class="a">→</span></a>
      <div class="fine">Join thousands of women building on their own terms. Unsubscribe anytime.</div>
    </div>
  </section>

  <section class="community-cta">
    <div class="news-in reveal">
      <div class="k">The Community</div>
      <h3>Bring it into the room</h3>
      <p>{pillar.community}</p>
      <a class="btn" href="/community">Join the community <span class="a">→</span></a>
    </div>
  </section>

  <footer>
    <div class="foot-in">
      <div>
        <div class="foot-brand">The Digital Income <em>Edit™</em></div>
        <div class="foot-tag">Build a business you're obsessed with — online, on your terms.</div>
      </div>
      <div class="foot-col">
        <h5>Learn</h5>
        <a href="/learn">The Library</a>
        <a href="/learn">Pinterest</a>
        <a href="/learn">AI</a>
        <a href="/learn">Digital Products</a>
      </div>
      <div class="foot-col">
        <h5>Explore</h5>
        <a href="/shop">Shop</a>
        <a href="/resources">Free Resources</a>
        <a href="/membership">Membership</a>
        <a href="/about">About</a>
      </div>
      <div class="foot-col">
        <h5>Connect</h5>
        <a href="/community">Community</a>
        <a href="/newsletter">Newsletter</a>
        <a href="#">Pinterest</a>
        <a href="#">Instagram</a>
      </div>
    </div>
    <div class="foot-bottom">
      <span>© 2026 The Digital Income Edit™</span>
      <span>Curated with intention.</span>
    </div>
  </footer>

  <script>
    document.body.classList.remove('no-js');
    const bar = document.getElementById('progress');
    addEventListener('scroll', () => {
      const h = document.documentElement;
      bar.style.width = (h.scrollTop / (h.scrollHeight - h.clientHeight) * 100) + '%';
    }, { passive: true });

    const io = new IntersectionObserver((es) => {
      es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
    }, { threshold: .01, rootMargin: '0px 0px 10% 0px' });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));

    const mio = new IntersectionObserver((es) => {
      es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); mio.unobserve(e.target); } });
    }, { threshold: 0, rootMargin: '0px 0px 15% 0px' });
    document.querySelectorAll('.mask').forEach(el => mio.observe(el));

    // Safety net: if any mask hasn't revealed shortly after load, reveal it.
    // Prevents tall images from staying hidden and leaving blank space.
    window.addEventListener('load', () => {
      setTimeout(() => {
        document.querySelectorAll('.mask:not(.in)').forEach(el => {
          const r = el.getBoundingClientRect();
          if (r.top < window.innerHeight * 1.5) el.classList.add('in');
        });
      }, 600);
    });

    const rm = matchMedia('(prefers-reduced-motion:reduce)').matches;
    if (!rm) {
      const px = [...document.querySelectorAll('.silence .img,.plate-photo .img,.chapter-cover .photo,.photo-quote .photo')];
      px.forEach(el => { el.style.transform = 'scale(1.08)'; el.style.transition = 'transform .1s linear'; });
      let ticking = false;
      const move = () => {
        px.forEach(el => {
          const host = el.classList.contains('photo') ? el.parentElement : el;
          const r = host.getBoundingClientRect();
          if (r.bottom > 0 && r.top < innerHeight) {
            const p = (r.top + r.height / 2 - innerHeight / 2) / innerHeight;
            el.style.transform = `scale(1.08) translateY(${(-p * 3).toFixed(2)}%)`;
          }
        });
        ticking = false;
      };
      addEventListener('scroll', () => { if (!ticking) { requestAnimationFrame(move); ticking = true; } }, { passive: true });
      move();
    }

    const links = [...document.querySelectorAll('#toc a')];
    const ids = links.map(a => document.querySelector(a.getAttribute('href')));
    const spy = new IntersectionObserver((es) => {
      es.forEach(e => { if (e.isIntersecting) { const id = '#' + e.target.id; links.forEach(a => a.classList.toggle('active', a.getAttribute('href') === id)); } });
    }, { rootMargin: '-40% 0px -55% 0px' });
    ids.forEach(s => s && spy.observe(s));

    const drawer = document.getElementById('drawer');
    document.getElementById('burger').onclick = () => drawer.classList.add('open');
    document.getElementById('close').onclick = () => drawer.classList.remove('open');
    drawer.querySelectorAll('a').forEach(a => a.onclick = () => drawer.classList.remove('open'));
  </script>
</body>
</html>
